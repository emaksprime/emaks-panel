APP_NAME="Emaks Prime Panel"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://dashboard.emaksprime.com.tr
APP_FORCE_HTTPS=true
ASSET_URL=https://dashboard.emaksprime.com.tr
TRUSTED_PROXIES=*

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=emaks_panel
DB_USERNAME=emaks_panel
DB_PASSWORD=
DB_SSLMODE=prefer
DATABASE_URL=
PGHOST=
PGPORT=
PGDATABASE=
PGUSER=
PGPASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.emaksprime.com.tr
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PANEL_BRAND="${APP_NAME}"
PANEL_DEFAULT_ROLE=admin
PANEL_PUBLIC_URL=https://dashboard.emaksprime.com.tr
PANEL_API_BASE_URL=https://dashboard.emaksprime.com.tr/api
PANEL_WEBHOOK_BASE_URL=https://dashboard.emaksprime.com.tr/api/workflows
PANEL_WORKFLOW_SALES_MAIN_URL=https://dashboard.emaksprime.com.tr/api/data/sales-main
PANEL_WORKFLOW_SALES_ONLINE_URL=https://dashboard.emaksprime.com.tr/api/workflows/sales-online/webhook
PANEL_WORKFLOW_SALES_BAYI_URL=https://dashboard.emaksprime.com.tr/api/workflows/sales-bayi/webhook
PANEL_WORKFLOW_STOCK_URL=https://dashboard.emaksprime.com.tr/api/workflows/stock/webhook
PANEL_WORKFLOW_ORDERS_URL=https://dashboard.emaksprime.com.tr/api/workflows/orders/webhook
PANEL_BOOTSTRAP_ADMIN_USERNAME=
PANEL_BOOTSTRAP_ADMIN_PASSWORD=
PANEL_BOOTSTRAP_ADMIN_NAME="Panel Administrator"
PANEL_BOOTSTRAP_ADMIN_REP_CODE=0003

VITE_APP_NAME="${APP_NAME}"
